# ============================================
# ArbiX Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://arbix:arbix_password@localhost:5432/arbix
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PRO=price_...

# Notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
SENDGRID_API_KEY=SG.your-sendgrid-key
FROM_EMAIL=alerts@arbix.io

# Scraping
PROXY_LIST=http://proxy1:port,http://proxy2:port
PROXY_USERNAME=username
PROXY_PASSWORD=password
SCRAPING_TIMEOUT=15000
SCRAPING_RETRIES=3

# Sportsbook APIs
PINNACLE_API_KEY=your-pinnacle-api-key
# Note: Most books require scraping - see adapters/

# App Config
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# AI (OpenAI for AI assistant)
OPENAI_API_KEY=sk-...

# Scanning
SCAN_INTERVAL_MS=5000
ARBITRAGE_MIN_ROI=0.5
MAX_CONCURRENT_SCRAPERS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
